# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Alpaca API (https://alpaca.markets) - used for both market data and trading
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # paper trading endpoint (safe for testing)
# ALPACA_BASE_URL=https://api.alpaca.markets      # live trading endpoint (uncomment when ready)

# Optional: Polygon.io (for production-grade data, upgrade from Alpaca free tier)
POLYGON_API_KEY=your_polygon_key_here

# Optional: Alpha Vantage (free historical daily data fallback)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
